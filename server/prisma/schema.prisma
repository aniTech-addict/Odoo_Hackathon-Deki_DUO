generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  avatar       String?
  password     String
  refreshToken String?
  type         String   @default("user")
  role         String   @default("user")
  isVerified     Boolean  @default(false)
  otpId          String?  @unique
  otp            Otp?     @relation(fields: [otpId], references: [id], onDelete: SetNull)
  failedAttempts Int      @default(0)
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Otp {
  id        String   @id @default(cuid())
  otp       String
  expireAt  DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?
}

model Vehicle {
  id                 String   @id @default(cuid())
  registrationNumber String   @unique
  model              String
  type               String[]
  capacityAmount     Float
  capacityUnit       String
  odometer           Float
  costAmount         Float
  costCurrency       String   @default("rupees")
  status             String   @default("available")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Driver {
  id              String   @id @default(cuid())
  name            String   @unique
  licenseNumber   String
  licenseCategory String
  licenseExpiry   String
  contactNumber   String
  safetyScore     Float    @default(100)
  status          String   @default("Available")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Trip {
  id              String   @id @default(cuid())
  route           String
  origin          String
  destination     String
  vehiclePlate    String
  driver          String
  departure       String
  cargoWeight     Float
  plannedDistance Float
  status          String   @default("Draft")
  progress        Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Expense {
  id        String   @id @default(cuid())
  category  String
  asset     String
  amount    Float
  date      String
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceLog {
  id        String   @id @default(cuid())
  title     String
  asset     String
  status    String   @default("Scheduled")
  cost      Float
  nextCheck String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}